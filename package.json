  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@supabase/supabase-js": "^2.110.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "sanitize-html": "^2.17.0",
    "stripe": "^22.3.2"
  },
  "engines": {
    "node": ">=22"
  }
}
