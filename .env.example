# Copy to .env and fill in. Without a key the app runs in demo mode
# (canned story content so you can preview the UI).
ANTHROPIC_API_KEY=sk-ant-...

# Accounts & cloud library (optional) — create a project at supabase.com,
# run supabase/schema.sql in its SQL editor, then fill these in from
# Project Settings → API. Without them the library is device-local only.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# Service-role key (server-only secret!) moves share storage into Supabase
# AND turns on story credits (sign-in + pay-per-story enforcement):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Payments (optional) — pay-per-story credits via Stripe. Requires the
# Supabase service-role key above. From dashboard.stripe.com:
#   STRIPE_SECRET_KEY   → Developers → API keys → Secret key (sk_live_… / sk_test_…)
#   STRIPE_WEBHOOK_SECRET → Developers → Webhooks → your endpoint's signing secret (whsec_…)
# The webhook endpoint URL is  https://YOUR-DOMAIN/api/stripe/webhook
# and must subscribe to the  checkout.session.completed  event.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CURRENCY=usd

# Optional overrides
# PORT=3000
# STORY_MODEL=claude-opus-4-8
# TARGET_CHAPTERS=10
# RATE_LIMIT_PER_HOUR=40
# DEMO_MODE=1
