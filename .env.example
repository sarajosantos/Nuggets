# Copy to .env and fill in. Without a key the app runs in demo mode
# (canned story content so you can preview the UI).
ANTHROPIC_API_KEY=sk-ant-...

# Accounts & cloud library (optional) — create a project at supabase.com,
# run supabase/schema.sql in its SQL editor, then fill these in from
# Project Settings → API. Without them the library is device-local only.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# Service-role key (server-only secret!) moves share storage into Supabase
# and enables server-owned story sessions, distributed limits, and operations:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Payments (optional) — pay-per-story credits via Stripe. Requires the
# Supabase service-role key above. From dashboard.stripe.com:
#   STRIPE_SECRET_KEY   → Developers → API keys → Secret key (sk_live_… / sk_test_…)
#   STRIPE_WEBHOOK_SECRET → Developers → Webhooks → your endpoint's signing secret (whsec_…)
# The webhook endpoint URL is  https://YOUR-DOMAIN/api/stripe/webhook
# and must subscribe to the  checkout.session.completed  event.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CURRENCY=usd
# PUBLIC_APP_URL=https://plotwick.com
#
# Credits are deliberately opt-in. The server refuses to start with credits
# enabled unless Checkout is fully configured (or an intentional pilot override
# is set). Prefer a restricted Stripe key (rk_...) with only required access.
# STORY_CREDITS_ENABLED=1
# ALLOW_FREE_ONLY_CREDITS=0

# Admin accounts (optional) — comma-separated emails that get unlimited
# stories and are never charged, for testing. They still sign in normally.
# ADMIN_EMAILS=you@example.com,teammate@example.com

# Optional overrides
# PORT=3000
# STORY_MODEL=claude-opus-4-8
# TARGET_CHAPTERS=10
# RATE_LIMIT_PER_HOUR=40
# DEMO_MODE=1
# REQUIRE_AUTH_FOR_LIVE=1
# AI_COVERS=0
# REPORT_HASH_SALT=replace-with-a-long-random-value
